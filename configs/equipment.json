  "dragDropRules": {
    "description": "Definiert welche Item-Typen in welche Equipment-Slots gedroppt werden dürfen",
    "rules": [
      {
        "targetSlot": "vest",
        "allowedTypes": ["vest", "armor"],
        "rejectMessage": "Nur Westen und Rüstungen können hier ausgerüstet werden"
      },
      {
        "targetSlot": "weapon",
        "allowedTypes": ["weapon", "tool"],
        "rejectMessage": "Nur Waffen und Werkzeuge können hier ausgerüstet werden"
      },
      {
        "targetSlot": "bag1",
        "allowedTypes": ["backpack", "large_bag"],
        "rejectMessage": "Nur Rucksäcke und große Taschen können hier ausgerüstet werden"
      },
      {
        "targetSlot": "bag2",
        "allowedTypes": ["hip_bag", "small_bag"],
        "rejectMessage": "Nur Bauchtaschen und kleine Taschen können hier ausgerüstet werden"
      }
    ]
  },
  "storageSystem": {
    "description": "Equipment mit hasStorage: true hat ein eigenes Inventar",
    "storageFormat": "equipment_storage:[itemName]:[uniqueId]",
    "examples": [
      "equipment_storage:backpack_medium:12345",
      "equipment_storage:hipbag_small:67890"
    ],
    "persistence": "Wird in equipment_storage Tabelle gespeichert (ähnlich wie vehicle_storage)",
    "uniqueIdGeneration": "UUID oder Timestamp-basiert beim ersten Equip"
  }
